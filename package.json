{
  "name": "App",
  "version": "1.0.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "jest --runInBand",
    "test:watch": "jest --runInBand --watch",
    "migration:create": "node-pg-migrate --migrations-dir infra/database/migrations create",
    "migration:up": "node-pg-migrate --migrations-dir infra/database/migrations --envPath .env up",
    "migration:down": "node-pg-migrate --migrations-dir infra/database/migrations --envPath .env down",
    "migrationEvo:up": "node-pg-migrate --migrations-dir infra/database/migrationEvo --envPath .env up",
    "migrationEvo:down": "node-pg-migrate --migrations-dir infra/database/migrationEvo --envPath .env down",
    "lint": "next lint"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.2",
    "@mui/lab": "^7.0.0-beta.17",
    "@mui/material": "^7.3.2",
    "@vercel/analytics": "^1.5.0",
    "lucide-react": "^0.543.0",
    "next": "^15.5.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-icons": "^5.5.0",
    "theme": "^0.1.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.24",
    "eslint": "^9.35.0",
    "eslint-config-next": "^15.5.3",
    "jest": "^29.7.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17"
  }
}
